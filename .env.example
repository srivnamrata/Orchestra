# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# LLM Configuration
LLM_MODEL=gemini-1.5-pro
USE_MOCK_LLM=true  # Set to false to use real Vertex AI

# Database Configuration
FIRESTORE_DATABASE=(default)
USE_FIRESTORE=false  # Set to true in production

# Pub/Sub Configuration
USE_MOCK_PUBSUB=true  # Set to false to use real Cloud Pub/Sub
PUBSUB_PROJECT_ID=your-gcp-project-id

# Agent Configuration
CRITIC_AGENT_ENABLED=true
CRITIC_EFFICIENCY_THRESHOLD=0.15  # Trigger replan if >15% improvement
CRITIC_CONFIDENCE_THRESHOLD=0.75  # Only replan if >75% confident

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Knowledge Graph Configuration
KNOWLEDGE_GRAPH_MAX_DEPTH=5

# Logging Configuration
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development  # development, testing, production
