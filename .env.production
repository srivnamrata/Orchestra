# Production Environment Configuration
# Used by Google Cloud Run deployments

# GCP Configuration
PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
ENVIRONMENT=production

# Firestore Configuration
FIRESTORE_MODE=production
FIRESTORE_DATABASE=default
FIRESTORE_COLLECTION_PREFIX=prod_

# Service Configuration
ORCHESTRATOR_PORT=8080
MCP_TASK_HOST=multi-agent-task
MCP_TASK_PORT=8001
MCP_CALENDAR_HOST=multi-agent-calendar
MCP_CALENDAR_PORT=8002
MCP_NOTES_HOST=multi-agent-notes
MCP_NOTES_PORT=8003
MCP_CRITIC_HOST=multi-agent-critic
MCP_CRITIC_PORT=8004
MCP_AUDITOR_HOST=multi-agent-auditor
MCP_AUDITOR_PORT=8005
MCP_EVENT_MONITOR_HOST=multi-agent-event-monitor
MCP_EVENT_MONITOR_PORT=8006

# Pub/Sub Configuration
PUBSUB_TOPIC_PREFIX=prod-
EVENT_TOPIC=prod-events
AUDIT_TOPIC=prod-audit
ERROR_TOPIC=prod-errors

# LLM Configuration
LLM_MODEL=models/gemini-1.5-pro
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Service Configuration
SERVICE_TIMEOUT=30
MCP_TIMEOUT=25
POOL_SIZE=10

# Security
REQUIRE_AUTH=true
API_KEY_HEADER=X-API-Key
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Performance
CACHE_TTL=3600
BATCH_SIZE=100
QUEUE_SIZE=1000

# Health Check
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
